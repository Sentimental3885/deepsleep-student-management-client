<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.deepsleep.ui.student.StudentAnalysisController">
    <VBox spacing="20" styleClass="page-root">
        <VBox spacing="6">
            <Label fx:id="pageTitle" styleClass="page-title"/>
            <Label fx:id="pageSubtitle" wrapText="true" styleClass="page-subtitle"/>
        </VBox>
        <FlowPane fx:id="statPane" hgap="12" vgap="12"/>
        <HBox spacing="10" styleClass="toolbar">
            <Button fx:id="refreshButton" text="刷新历史" onAction="#onRefresh" styleClass="secondary-button"/>
            <Button fx:id="createButton" text="生成分析" onAction="#onCreate" styleClass="primary-button"/>
            <Button fx:id="editButton" text="查看详情" onAction="#onEdit" styleClass="secondary-button"/>
        </HBox>
        <TableView fx:id="dataTable" prefHeight="220"/>
        <VBox fx:id="formBox" spacing="12" styleClass="form-panel"/>
        <TextArea fx:id="contentArea" editable="false" visible="false" managed="false" wrapText="true"/>
        <Label fx:id="emptyState" wrapText="true" styleClass="empty-state"/>
    </VBox>
</ScrollPane>
