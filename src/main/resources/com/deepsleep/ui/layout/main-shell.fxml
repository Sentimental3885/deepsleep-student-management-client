<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="shell-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.deepsleep.ui.layout.MainShellController">
    <left>
        <VBox spacing="8" prefWidth="230" styleClass="sidebar">
            <Label text="DeepSleep" styleClass="sidebar-title"/>
            <Label text="教务管理工作台" styleClass="sidebar-subtitle"/>
            <VBox fx:id="navigationBox" spacing="4" VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
            <Label fx:id="sectionTitleLabel" text="工作台" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label fx:id="userNameLabel" styleClass="user-name"/>
                <Label fx:id="userRoleLabel" styleClass="user-role"/>
            </VBox>
            <Button text="退出" onAction="#onLogout" styleClass="secondary-button"/>
        </HBox>
    </top>
    <center>
        <StackPane fx:id="contentHost"/>
    </center>
</BorderPane>
